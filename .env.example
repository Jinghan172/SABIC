# =====================================================
# 复制本文件为 .env.local 后填入实际值
# .env.local 已在 .gitignore，不会提交代码仓库
# =====================================================

# 企查查开放平台凭证（https://openapi.qcc.com/）
# 注册后在"我的接口"页面获取
QCC_APP_KEY=
QCC_SECRET_KEY=

# PubChem（无需 Key，true 启用化学品详情查询）
PUBCHEM_ENABLED=true

# 高德地图（P4 阶段接入，现在可留空）
AMAP_KEY=
